generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  ADMIN
}

enum ScoringType {
  SUM
  AVERAGE
}

enum QuestionType {
  SCALE
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TEXT
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AttemptStatus {
  NEW
  REVIEWED
  NEEDS_DISCUSSION
  CLOSED
}

enum RiskOperator {
  EQUAL
  NOT_EQUAL
  GREATER_THAN
  GREATER_OR_EQUAL
  LESS_THAN
  LESS_OR_EQUAL
}

enum BibliographySource {
  CROSSREF
  GOOGLE_BOOKS
  OPENAI_WEB
  MANUAL
}

enum AnswerMode {
  SHARED
  PER_QUESTION
}

enum ScoringMode {
  TOTAL
  MULTISCALE
}

model BibliographyItem {
  id       String             @id @default(cuid())
  rawInput String
  source   BibliographySource
  cslJson  Json

  title    String?
  itemType String?
  doi      String? @unique
  isbn     String?
  url      String?

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
  @@index([itemType])
  @@index([title])
  @@index([isbn])
  @@index([url])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(STUDENT)

  accounts Account[]
  sessions Session[]

  attempts TestAttempt[] @relation("UserAttempts")
  reviews  TestAttempt[] @relation("ReviewedAttempts")

  bibliographyItems BibliographyItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Test {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  description String  @db.Text
  instruction String? @db.Text

  scoringType ScoringType @default(SUM)
  scoringMode ScoringMode @default(TOTAL)
  answerMode  AnswerMode  @default(SHARED)

  isActive    Boolean @default(true)
  timeMinutes Int?

  questions     Question[]
  answerOptions AnswerOption[]
  ranges        TestRange[]
  attempts      TestAttempt[]
  riskRules     RiskRule[]
  scales        TestScale[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Question {
  id      String  @id @default(cuid())
  testId  String
  scaleId String?

  text       String       @db.Text
  helpText   String?      @db.Text
  type       QuestionType @default(SCALE)
  order      Int
  isRequired Boolean      @default(true)

  test          Test           @relation(fields: [testId], references: [id], onDelete: Cascade)
  scale         TestScale?     @relation(fields: [scaleId], references: [id], onDelete: SetNull)
  answerOptions AnswerOption[]
  answers       TestAnswer[]
  riskRules     RiskRule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([testId, order])
  @@index([testId])
  @@index([scaleId])
}

model AnswerOption {
  id         String  @id @default(cuid())
  testId     String
  questionId String?

  label String
  value Int
  order Int

  isRiskMarker Boolean   @default(false)
  riskMessage  String?   @db.Text
  riskSeverity Severity?

  test     Test      @relation(fields: [testId], references: [id], onDelete: Cascade)
  question Question? @relation(fields: [questionId], references: [id], onDelete: Cascade)

  answers   TestAnswer[]
  riskRules RiskRule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([questionId, order])
  @@index([testId])
  @@index([questionId])
  @@index([testId, questionId])
  @@index([isRiskMarker])
}

model TestRange {
  id      String  @id @default(cuid())
  testId  String
  scaleId String?

  minScore       Float
  maxScore       Float
  title          String
  description    String   @db.Text
  recommendation String?  @db.Text
  severity       Severity

  test  Test       @relation(fields: [testId], references: [id], onDelete: Cascade)
  scale TestScale? @relation(fields: [scaleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([testId])
  @@index([scaleId])
  @@index([severity])
}

model TestAttempt {
  id                String        @id @default(cuid())
  userId            String
  testId            String
  totalScore        Float
  resultTitle       String
  resultDescription String        @db.Text
  recommendation    String?       @db.Text
  severity          Severity
  hasRiskMarker     Boolean       @default(false)
  riskMessage       String?       @db.Text
  status            AttemptStatus @default(NEW)
  adminComment      String?       @db.Text
  reviewedById      String?
  reviewedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user       User  @relation("UserAttempts", fields: [userId], references: [id], onDelete: Cascade)
  test       Test  @relation(fields: [testId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("ReviewedAttempts", fields: [reviewedById], references: [id], onDelete: SetNull)

  answers TestAnswer[]

  scaleResults TestScaleResult[]

  @@index([userId])
  @@index([testId])
  @@index([status])
  @@index([severity])
  @@index([hasRiskMarker])
  @@index([createdAt])
  @@index([reviewedById])
}

model TestAnswer {
  id             String  @id @default(cuid())
  attemptId      String
  questionId     String
  answerOptionId String?

  value     Int?
  label     String?
  textValue String? @db.Text

  attempt      TestAttempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question     Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answerOption AnswerOption? @relation(fields: [answerOptionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([attemptId])
  @@index([questionId])
  @@index([answerOptionId])
}

model TestScale {
  id          String  @id @default(cuid())
  testId      String
  code        String
  title       String
  description String? @db.Text
  multiplier  Float   @default(1)

  test      Test              @relation(fields: [testId], references: [id], onDelete: Cascade)
  questions Question[]
  ranges    TestRange[]
  results   TestScaleResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([testId, code])
  @@index([testId])
}

model TestScaleResult {
  id        String @id @default(cuid())
  attemptId String
  scaleId   String

  rawScore   Float
  finalScore Float

  resultTitle       String
  resultDescription String   @db.Text
  recommendation    String?  @db.Text
  severity          Severity

  attempt TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  scale   TestScale   @relation(fields: [scaleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([attemptId, scaleId])
  @@index([attemptId])
  @@index([scaleId])
}

model RiskRule {
  id             String  @id @default(cuid())
  testId         String
  questionId     String
  answerOptionId String?

  operator RiskOperator
  value    Int?

  message  String   @db.Text
  severity Severity
  isActive Boolean  @default(true)

  test         Test          @relation(fields: [testId], references: [id], onDelete: Cascade)
  question     Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answerOption AnswerOption? @relation(fields: [answerOptionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([testId])
  @@index([questionId])
  @@index([answerOptionId])
  @@index([isActive])
  @@index([severity])
}
